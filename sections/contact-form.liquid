{%- comment -%}
  ============================================================
  CONTACT FORM — formulário de contato nativo
  ============================================================

  O QUE FAZ:
  Renderiza o formulário de contato usando {% form 'contact' %} do
  Shopify (envia email para a loja). Campos: nome, email (required),
  telefone e mensagem. Mostra avisos de sucesso e de erros de validação.

  ONDE É USADA:
  Template page.contact (ou onde a seção for adicionada via preset).

  PRINCIPAIS PARTES:
  - form 'contact': envio nativo, sem backend próprio
  - Pré-preenche valores com dados do customer, se logado
  - Bloco de erros com âncoras para cada campo inválido
  - Telefone usa type="tel"; textarea tem resize desativado
  - Setting: heading; tem preset (aparece no theme editor)

  OBSERVAÇÕES:
  Os name= de nome/telefone usam a label traduzida (padrão Shopify).
{%- endcomment -%}

{%- assign form_id = 'ContactForm-' | append: section.id -%}

<section class="contact page-width" data-section-id="{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <h1 class="contact__heading">{{ section.settings.heading | escape }}</h1>
  {%- endif -%}

  {%- form 'contact', id: form_id, class: 'contact__form' -%}
    {%- if form.posted_successfully? -%}
      <div class="contact__notice contact__notice--success" role="status" tabindex="-1">
        {{ 'templates.contact.form.post_success' | t }}
      </div>
    {%- elsif form.errors -%}
      <div class="contact__notice contact__notice--error" role="alert" tabindex="-1">
        <h2 class="contact__notice-title">{{ 'templates.contact.form.error_heading' | t }}</h2>
        <ul class="contact__errors" role="list">
          {%- for field in form.errors -%}
            <li>
              {%- if field == 'form' -%}
                {{ form.errors.messages[field] }}
              {%- else -%}
                <a href="#ContactForm-{{ field }}-{{ section.id }}">
                  {{ form.errors.translated_fields[field] | capitalize }}
                  {{ form.errors.messages[field] }}
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    <div class="contact__field">
      <label class="field__label" for="ContactForm-name-{{ section.id }}">
        {{ 'templates.contact.form.name' | t }}
      </label>
      <input
        type="text"
        class="field__input"
        id="ContactForm-name-{{ section.id }}"
        name="contact[{{ 'templates.contact.form.name' | t }}]"
        value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
        autocomplete="name"
        spellcheck="false"
      >
    </div>

    <div class="contact__field">
      <label class="field__label" for="ContactForm-email-{{ section.id }}">
        {{ 'templates.contact.form.email' | t }}
      </label>
      <input
        type="email"
        class="field__input"
        id="ContactForm-email-{{ section.id }}"
        name="contact[email]"
        value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
        autocomplete="email"
        autocapitalize="off"
        spellcheck="false"
        required
      >
    </div>

    <div class="contact__field">
      <label class="field__label" for="ContactForm-phone-{{ section.id }}">
        {{ 'templates.contact.form.phone' | t }}
      </label>
      <input
        type="tel"
        class="field__input"
        id="ContactForm-phone-{{ section.id }}"
        name="contact[{{ 'templates.contact.form.phone' | t }}]"
        value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
        autocomplete="tel"
        spellcheck="false"
      >
    </div>

    <div class="contact__field">
      <label class="field__label" for="ContactForm-body-{{ section.id }}">
        {{ 'templates.contact.form.comment' | t }}
      </label>
      <textarea
        rows="6"
        class="field__input contact__textarea"
        id="ContactForm-body-{{ section.id }}"
        name="contact[body]"
        spellcheck="false"
      >{% if form.body %}{{ form.body }}{% endif %}</textarea>
    </div>

    <button type="submit" class="button contact__submit">
      {{ 'templates.contact.form.send' | t }}
    </button>
  {%- endform -%}
</section>

<style>
  .contact {
    padding-top: var(--spacing-sections, 40px);
    padding-bottom: var(--spacing-sections, 40px);
    max-width: 720px;
  }

  .contact__heading {
    margin-bottom: 32px;
    font-size: var(--f7);
    text-align: center;
  }

  .contact__field {
    margin-bottom: 20px;
  }

  .contact__textarea {
    resize: none;
  }

  .contact__notice {
    margin-bottom: 24px;
    padding: 14px 18px;
    border-radius: var(--inputs-radius, 4px);
    font-size: var(--f2);
  }

  .contact__notice--success {
    color: var(--color-accent-text, #fff);
    background-color: var(--color-sale, #1cb744);
  }

  .contact__notice--error {
    color: var(--color-text, #000);
    border: 1px solid var(--color-sale, #d02e2e);
  }

  .contact__notice-title {
    font-size: var(--f3);
    margin-bottom: 8px;
  }

  .contact__errors {
    margin: 0;
    padding-left: 1.2em;
  }

  .contact__errors a {
    color: inherit;
  }

  .contact__submit {
    margin-top: 8px;
  }

  @media screen and (max-width: 1000px) {
    .contact__heading {
      font-size: var(--f6);
    }
  }
</style>

{% schema %}
{
  "name": "t:sections.contact_form.name",
  "tag": "section",
  "class": "section-contact-form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.contact_form.settings.heading.label",
      "default": "Contact"
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact_form.name"
    }
  ]
}
{% endschema %}
