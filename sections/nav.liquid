{%- comment -%}
  ============================================================
  NAV / HEADER — cabeçalho do site
  ============================================================

  O QUE FAZ:
  Monta o cabeçalho da loja: logo, navegação de múltiplos níveis
  (menu com submenus e sub-submenus), busca, link de conta,
  contador do carrinho e seletores de localização (país/moeda e
  idioma). Inclui menu mobile com botão hambúrguer.

  ONDE É USADA:
  No layout (layout/theme.liquid), como header fixo presente em
  todas as páginas. É uma section de grupo/header do tema.

  PRINCIPAIS PARTES:
  - Logo: usa settings.logo (imagem) ou, se vazio, o nome da loja
    (shop.name) como texto.
  - header__nav: percorre section.settings.menu.links montando o
    menu desktop com até 3 níveis (link > child > grandchild).
  - header__actions: busca (details com painel), conta (só se
    customer_accounts_enabled) e carrinho com contador
    data-cart-count baseado em cart.item_count.
  - Localização: renderiza o snippet 'localization-form' conforme
    os settings enable_country_selector / enable_language_selector.
  - header__mobile-nav: menu alternativo para telas <= 1000px,
    aberto/fechado pelo <script> que alterna aria-expanded/hidden.

  OBSERVAÇÕES:
  - Ícones vêm do snippet 'icon' (search, account, cart, etc.).
  - O menu é definido no setting menu (link_list, default
    "main-menu"); submenus só aparecem se o link tiver filhos.
  - Estilos e o JS do toggle mobile ficam inline neste arquivo.
{%- endcomment -%}
{%- if section.settings.show_announcement and section.settings.announcement_text != blank -%}
  <div class="header-announcement" data-section-id="{{ section.id }}">
    <div class="page-width header-announcement__inner">
      <span class="header-announcement__text">{{ section.settings.announcement_text | escape }}</span>
    </div>
  </div>
{%- endif -%}

<header class="header page-width" data-section-id="{{ section.id }}">
  <div class="header__inner">
    <button
      type="button"
      class="header__menu-toggle tap-target"
      aria-label="{{ 'sections.header.menu' | t }}"
      aria-expanded="false"
      aria-controls="MobileNav-{{ section.id }}"
    >
      <span class="header__burger"></span>
    </button>

    <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name | escape }}">
      {%- if settings.logo != blank -%}
        {%- assign logo_alt = shop.name | escape -%}
        {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
        {{
          settings.logo
          | image_url: width: 600
          | image_tag:
            class: 'header__logo-image',
            widths: '150, 300, 450, 600',
            width: settings.logo_width,
            height: logo_height,
            alt: logo_alt,
            sizes: '(max-width: 1000px) 40vw, 200px'
        }}
      {%- else -%}
        {%- assign brand_initial = shop.name | strip | slice: 0 | upcase -%}
        <span class="header__logo-wordmark">
          <span class="header__logo-mark" aria-hidden="true">{{ brand_initial }}</span>
          <span class="header__logo-text">{{ shop.name }}</span>
        </span>
      {%- endif -%}
    </a>

    <nav class="header__nav" role="navigation" aria-label="{{ 'sections.header.menu' | t }}">
      <ul class="header__menu" role="list">
        {%- for link in section.settings.menu.links -%}
          <li class="header__menu-item {% if link.links != blank %}header__menu-item--has-dropdown{% endif %}">
            <a href="{{ link.url }}" class="header__menu-link" {% if link.current %}aria-current="page"{% endif %}>
              {{ link.title | escape }}
            </a>
            {%- if link.links != blank -%}
              <ul class="header__submenu" role="list">
                {%- for child in link.links -%}
                  <li class="header__submenu-item {% if child.links != blank %}header__submenu-item--has-dropdown{% endif %}">
                    <a href="{{ child.url }}" class="header__submenu-link">{{ child.title | escape }}</a>
                    {%- if child.links != blank -%}
                      <ul class="header__submenu header__submenu--nested" role="list">
                        {%- for grandchild in child.links -%}
                          <li><a href="{{ grandchild.url }}" class="header__submenu-link">{{ grandchild.title | escape }}</a></li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    <div class="header__actions">
      <details class="header__search">
        <summary class="header__action-button tap-target" aria-label="{{ 'general.search.search' | t }}">
          {% render 'icon', name: 'search' %}
        </summary>
        <div class="header__search-panel">
          <form action="{{ routes.search_url }}" method="get" role="search" class="header__search-form">
            <input
              type="search"
              name="q"
              value="{{ search.terms | escape }}"
              placeholder="{{ 'general.search.placeholder' | t }}"
              aria-label="{{ 'general.search.search' | t }}"
              class="field__input"
            >
            <button type="submit" class="visually-hidden">{{ 'general.search.submit' | t }}</button>
          </form>
        </div>
      </details>

      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="header__action-button tap-target" aria-label="{{ 'customer.account.title' | t }}">
          {% render 'icon', name: 'account' %}
        </a>
      {%- endif -%}

      {%- if section.settings.show_wishlist -%}
        <a href="{{ section.settings.wishlist_link | default: routes.all_products_collection_url }}" class="header__action-button tap-target" aria-label="Wishlist">
          {% render 'icon', name: 'heart' %}
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="header__action-button header__cart tap-target" aria-label="{{ 'templates.cart.cart' | t }}">
        {% render 'icon', name: 'cart' %}
        <span class="header__cart-count" data-cart-count>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>

  {%- if section.settings.enable_country_selector or section.settings.enable_language_selector -%}
    <div class="header__localization">
      {% render 'localization-form',
        section_id: section.id,
        show_country: section.settings.enable_country_selector,
        show_language: section.settings.enable_language_selector
      %}
    </div>
  {%- endif -%}
</header>

<div class="header__mobile-nav" id="MobileNav-{{ section.id }}" hidden>
  <ul class="header__mobile-menu" role="list">
    {%- for link in section.settings.menu.links -%}
      <li>
        <a href="{{ link.url }}" class="header__mobile-link">{{ link.title | escape }}</a>
        {%- if link.links != blank -%}
          <ul role="list" class="header__mobile-submenu">
            {%- for child in link.links -%}
              <li><a href="{{ child.url }}" class="header__mobile-link header__mobile-link--child">{{ child.title | escape }}</a></li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
</div>

<style>
  /* Barra de anúncio */
  .header-announcement {
    background-color: var(--color-accent);
    color: var(--color-accent-text);
  }
  .header-announcement__inner { padding: 9px 20px; text-align: center; }
  .header-announcement__text {
    font-size: var(--f1);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* Header */
  .section-header .header,
  .header { position: relative; }
  .header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 20px;
    padding: 20px 0;
  }
  .header__nav { justify-self: start; }
  .header__logo-link { justify-self: center; text-decoration: none; color: var(--color-text); }
  .header__actions { justify-self: end; }

  .header__logo-image { display: block; height: auto; }
  .header__logo-wordmark { display: inline-flex; align-items: center; gap: 12px; }
  .header__logo-mark {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    font-family: var(--font-heading-family);
    font-size: 1.3rem;
    line-height: 1;
    color: var(--color-accent-text);
    background-color: var(--color-accent);
    border-radius: 50%;
  }
  .header__logo-text {
    font-family: var(--font-heading-family);
    font-size: var(--f5);
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  .header__menu {
    display: flex;
    align-items: center;
    gap: 30px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .header__menu-item { position: relative; }
  .header__menu-link {
    position: relative;
    font-family: var(--font-body-family);
    font-size: var(--f2);
    letter-spacing: 0.02em;
    color: var(--color-text);
    text-decoration: none;
    padding: 10px 0;
    display: inline-block;
  }
  .header__menu-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 2px;
    width: 100%;
    height: 1.5px;
    background-color: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }
  .header__menu-link:hover::after,
  .header__menu-item--has-dropdown:hover > .header__menu-link::after,
  .header__menu-link[aria-current="page"]::after { transform: scaleX(1); }

  .header__submenu-link {
    font-family: var(--font-body-family);
    font-size: var(--f2);
    color: var(--color-text);
    text-decoration: none;
    display: inline-block;
  }
  .header__submenu {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 220px;
    margin: 0;
    padding: 10px 0;
    list-style: none;
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    box-shadow: 0 18px 40px rgba(35, 26, 20, 0.12);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
    z-index: 20;
  }
  .header__submenu--nested { top: 0; left: 100%; }
  .header__menu-item--has-dropdown:hover > .header__submenu,
  .header__menu-item--has-dropdown:focus-within > .header__submenu,
  .header__submenu-item--has-dropdown:hover > .header__submenu,
  .header__submenu-item--has-dropdown:focus-within > .header__submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .header__submenu-item { position: relative; }
  .header__submenu-link { padding: 8px 18px; width: 100%; transition: background-color 0.15s ease; }
  .header__submenu-link:hover { background-color: var(--color-background-contrast); }

  .header__actions { display: flex; align-items: center; gap: 4px; }
  .header__action-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
    width: 44px;
    height: 44px;
    color: var(--color-text);
    background: none;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    text-decoration: none;
    transition: background-color 0.15s ease;
  }
  .header__action-button:hover { background-color: var(--color-background-contrast); }
  .header__action-button svg { width: 21px; height: 21px; }
  .header__cart-count {
    position: absolute;
    top: 4px;
    right: 4px;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    font-size: 11px;
    font-weight: 700;
    line-height: 18px;
    text-align: center;
    color: var(--color-accent-text);
    background-color: var(--color-accent);
    border-radius: 9px;
  }
  .header__search { position: relative; }
  .header__search summary { list-style: none; }
  .header__search summary::-webkit-details-marker { display: none; }
  .header__search-panel {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    width: 340px;
    max-width: 90vw;
    padding: 14px;
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 18px;
    box-shadow: 0 18px 40px rgba(35, 26, 20, 0.14);
    z-index: 20;
  }
  .header__menu-toggle { display: none; justify-self: start; background: none; border: none; }
  .header__burger,
  .header__burger::before,
  .header__burger::after {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-text);
    border-radius: 2px;
    transition: transform 0.2s ease;
  }
  .header__burger { position: relative; }
  .header__burger::before { content: ''; position: absolute; top: -7px; }
  .header__burger::after { content: ''; position: absolute; top: 7px; }
  .header__mobile-nav {
    padding: 8px 20px 20px;
    border-top: 1px solid var(--color-border);
  }
  .header__mobile-menu, .header__mobile-submenu { list-style: none; margin: 0; padding: 0; }
  .header__mobile-link { display: block; padding: 14px 0; font-family: var(--font-heading-family); font-size: var(--f4); color: var(--color-text); text-decoration: none; border-bottom: 1px solid var(--color-border); }
  .header__mobile-submenu .header__mobile-link { font-family: var(--font-body-family); }
  .header__mobile-link--child { padding-left: 16px; font-size: var(--f2); opacity: 0.75; border-bottom: none; }
  .header__localization { padding: 8px 0 14px; display: flex; justify-content: flex-end; }

  @media screen and (max-width: 1000px) {
    .header__inner { grid-template-columns: auto 1fr auto; padding: 16px 0; }
    .header__nav { display: none; }
    .header__menu-toggle { display: inline-flex; }
    .header__logo-link { justify-self: center; }
    .header__logo-mark { width: 34px; height: 34px; font-size: 1.1rem; }
    .header__logo-text { font-size: var(--f3); }
    .header__localization { justify-content: flex-start; }
  }
  @media screen and (min-width: 1001px) {
    .header__mobile-nav { display: none !important; }
  }
</style>

<script>
  (function () {
    var section = document.querySelector('.header[data-section-id="{{ section.id }}"]');
    if (!section) return;
    var toggle = section.querySelector('.header__menu-toggle');
    var nav = document.getElementById('MobileNav-{{ section.id }}');
    if (toggle && nav) {
      toggle.addEventListener('click', function () {
        var open = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!open));
        nav.hidden = open;
      });
    }
  })();
</script>

{% schema %}
{
  "name": "t:sections.header.name",
  "class": "section-header",
  "settings": [
    {
      "type": "header",
      "content": "Barra de anúncio"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "default": true,
      "label": "Mostrar barra de anúncio"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "default": "Frete grátis acima de R$299 · Troca fácil em 30 dias",
      "label": "Texto do anúncio"
    },
    {
      "type": "header",
      "content": "Navegação"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "t:sections.header.settings.menu.label"
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "default": true,
      "label": "Mostrar ícone de wishlist"
    },
    {
      "type": "url",
      "id": "wishlist_link",
      "label": "Link da wishlist"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__localization.content"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": true,
      "label": "t:sections.header.settings.enable_country_selector.label"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": true,
      "label": "t:sections.header.settings.enable_language_selector.label"
    }
  ]
}
{% endschema %}
