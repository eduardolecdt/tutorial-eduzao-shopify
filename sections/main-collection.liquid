{%- comment -%}
  ============================================================
  MAIN COLLECTION — grade de produtos de uma coleção
  ============================================================

  O QUE FAZ:
  Mostra a grade de produtos de uma coleção com ordenação,
  filtros facetados e paginação nativos do Shopify. Tudo funciona
  sem JavaScript, pois usa formulários GET.

  ONDE É USADA:
  No template de coleção (templates/collection.json), como section
  principal que lista os produtos da coleção atual.

  PRINCIPAIS PARTES:
  - {% paginate %}: pagina collection.products conforme o setting
    products_per_page.
  - Toolbar de filtros (form GET): percorre collection.filters e
    monta cada tipo (list/boolean com checkboxes e price_range com
    inputs de mín/máx). Preserva o sort ativo via input hidden.
  - Toolbar de ordenação (form GET): select com
    collection.sort_options que faz submit no onchange; preserva
    os filtros ativos via inputs hidden. Tem fallback <noscript>.
  - Estado vazio (collection__empty) quando não há produtos.
  - Grade: product-grid renderizando o snippet 'card-product'
    para cada produto, seguida do snippet 'pagination'.

  OBSERVAÇÕES:
  - As colunas do desktop vêm do setting columns_desktop, aplicado
    via variável CSS inline --grid-columns.
  - Filtros e ordenação podem ser desligados pelos settings
    enable_filtering e enable_sorting.
  - Estilos ficam inline no <style>, escopados por
    #shopify-section-{{ section.id }}.
{%- endcomment -%}

{%- paginate collection.products by section.settings.products_per_page -%}
  <div
    class="collection page-width"
    data-section-id="{{ section.id }}"
    style="--grid-columns: {{ section.settings.columns_desktop }};"
  >
    {%- if section.settings.enable_sorting or section.settings.enable_filtering -%}
      <div class="collection__toolbar">
        {%- if section.settings.enable_filtering and collection.filters.size > 0 -%}
          <form method="get" class="collection__filters" id="CollectionFilters-{{ section.id }}">
            {%- comment -%} Preserve current sort when filtering {%- endcomment -%}
            {%- if collection.sort_by != blank -%}
              <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
            {%- endif -%}

            {%- for filter in collection.filters -%}
              <details class="collection__filter">
                <summary class="collection__filter-summary">{{ filter.label | escape }}</summary>
                <div class="collection__filter-content">
                  {%- case filter.type -%}
                    {%- when 'list', 'boolean' -%}
                      <ul class="collection__filter-values" role="list">
                        {%- for value in filter.values -%}
                          <li class="collection__filter-value">
                            <label>
                              <input
                                type="checkbox"
                                name="{{ value.param_name }}"
                                value="{{ value.value }}"
                                {% if value.active %}checked{% endif %}
                                {% if value.count == 0 and value.active == false %}disabled{% endif %}
                              >
                              <span>{{ value.label | escape }}</span>
                              <span class="collection__filter-count">({{ value.count }})</span>
                            </label>
                          </li>
                        {%- endfor -%}
                      </ul>

                    {%- when 'price_range' -%}
                      <div class="collection__filter-price">
                        <div class="collection__filter-price-field">
                          <label
                            class="field__label"
                            for="Filter-{{ filter.label | escape }}-min-{{ section.id }}"
                          >
                            {{ 'products.facets.from' | t }}
                          </label>
                          <input
                            class="field__input"
                            type="number"
                            name="{{ filter.min_value.param_name }}"
                            id="Filter-{{ filter.label | escape }}-min-{{ section.id }}"
                            min="0"
                            max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                            {% if filter.min_value.value %}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                            placeholder="0"
                          >
                        </div>
                        <div class="collection__filter-price-field">
                          <label
                            class="field__label"
                            for="Filter-{{ filter.label | escape }}-max-{{ section.id }}"
                          >
                            {{ 'products.facets.to' | t }}
                          </label>
                          <input
                            class="field__input"
                            type="number"
                            name="{{ filter.max_value.param_name }}"
                            id="Filter-{{ filter.label | escape }}-max-{{ section.id }}"
                            min="0"
                            max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                            {% if filter.max_value.value %}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                            placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                          >
                        </div>
                      </div>
                  {%- endcase -%}
                </div>
              </details>
            {%- endfor -%}

            <div class="collection__filter-actions">
              <button type="submit" class="button">{{ 'products.facets.apply' | t }}</button>
              <a href="{{ collection.url }}" class="button button--secondary">
                {{ 'products.facets.clear_all' | t }}
              </a>
            </div>
          </form>
        {%- endif -%}

        <div class="collection__toolbar-bar">
          <span class="collection__count">
            {{- 'products.facets.product_count_simple' | t: count: collection.products_count -}}
          </span>

          {%- if section.settings.enable_sorting -%}
            <form method="get" class="collection__sort">
              {%- comment -%} Preserve active filters when sorting {%- endcomment -%}
              {%- for filter in collection.filters -%}
                {%- for value in filter.values -%}
                  {%- if value.active -%}
                    <input type="hidden" name="{{ value.param_name }}" value="{{ value.value }}">
                  {%- endif -%}
                {%- endfor -%}
                {%- if filter.type == 'price_range' -%}
                  {%- if filter.min_value.value -%}
                    <input
                      type="hidden"
                      name="{{ filter.min_value.param_name }}"
                      value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                    >
                  {%- endif -%}
                  {%- if filter.max_value.value -%}
                    <input
                      type="hidden"
                      name="{{ filter.max_value.param_name }}"
                      value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                    >
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}

              <label class="field__label collection__sort-label" for="SortBy-{{ section.id }}">
                {{ 'products.facets.sort_by_label' | t }}
              </label>
              <select
                name="sort_by"
                id="SortBy-{{ section.id }}"
                class="select__select"
                onchange="this.form.submit()"
              >
                {%- for option in collection.sort_options -%}
                  <option
                    value="{{ option.value }}"
                    {% if option.value == collection.sort_by %}selected{% endif %}
                  >
                    {{ option.name }}
                  </option>
                {%- endfor -%}
              </select>
              <noscript>
                <button type="submit" class="button button--secondary">
                  {{ 'products.facets.apply' | t }}
                </button>
              </noscript>
            </form>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- if collection.products.size == 0 -%}
      <div class="collection__empty">
        <p>{{ 'sections.main_collection.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="button button--secondary">
          {{ 'sections.main_collection.use_fewer_filters' | t }}
        </a>
      </div>
    {%- else -%}
      <ul class="product-grid" role="list">
        {%- for product in collection.products -%}
          <li class="product-grid__item">
            {% render 'card-product', card_product: product %}
          </li>
        {%- endfor -%}
      </ul>

      {% render 'pagination', paginate: paginate %}
    {%- endif -%}
  </div>
{%- endpaginate -%}

<style>
  #shopify-section-{{ section.id }} .collection {
    margin-bottom: var(--spacing-sections, 40px);
  }
  #shopify-section-{{ section.id }} .collection__toolbar {
    margin-bottom: 24px;
  }
  #shopify-section-{{ section.id }} .collection__filters {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 12px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-border, #c2c2c2);
  }
  #shopify-section-{{ section.id }} .collection__filter {
    position: relative;
  }
  #shopify-section-{{ section.id }} .collection__filter-summary {
    cursor: pointer;
    padding: 8px 12px;
    font-size: var(--f2);
    border: 1px solid var(--color-border, #c2c2c2);
    border-radius: var(--inputs-radius, 4px);
    list-style: none;
    user-select: none;
  }
  #shopify-section-{{ section.id }} .collection__filter-summary::-webkit-details-marker {
    display: none;
  }
  #shopify-section-{{ section.id }} .collection__filter-content {
    margin-top: 8px;
    padding: 12px;
    border: 1px solid var(--color-border, #c2c2c2);
    border-radius: var(--inputs-radius, 4px);
    background-color: var(--color-background, #fff);
  }
  #shopify-section-{{ section.id }} .collection__filter-values {
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 260px;
    overflow-y: auto;
  }
  #shopify-section-{{ section.id }} .collection__filter-value label {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 0;
    font-size: var(--f2);
    cursor: pointer;
  }
  #shopify-section-{{ section.id }} .collection__filter-count {
    opacity: 0.6;
    font-size: var(--f1);
  }
  #shopify-section-{{ section.id }} .collection__filter-price {
    display: flex;
    gap: 12px;
  }
  #shopify-section-{{ section.id }} .collection__filter-price-field {
    flex: 1;
  }
  #shopify-section-{{ section.id }} .collection__filter-actions {
    display: flex;
    gap: 8px;
    align-items: flex-end;
  }
  #shopify-section-{{ section.id }} .collection__toolbar-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 16px;
  }
  #shopify-section-{{ section.id }} .collection__count {
    font-size: var(--f2);
    opacity: 0.8;
  }
  #shopify-section-{{ section.id }} .collection__sort {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  #shopify-section-{{ section.id }} .collection__sort-label {
    margin-bottom: 0;
    white-space: nowrap;
  }
  #shopify-section-{{ section.id }} .collection__sort .select__select {
    width: auto;
    min-width: 200px;
  }
  #shopify-section-{{ section.id }} .collection__empty {
    text-align: center;
    padding: 60px 0;
    font-size: var(--f3);
  }
  #shopify-section-{{ section.id }} .collection__empty .button {
    margin-top: 20px;
  }
  #shopify-section-{{ section.id }} .pagination {
    margin-top: 40px;
  }
  #shopify-section-{{ section.id }} .pagination__list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 6px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  #shopify-section-{{ section.id }} .pagination__item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    min-height: 40px;
    padding: 0 8px;
    font-size: var(--f2);
    color: var(--color-text, #000);
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: var(--inputs-radius, 4px);
  }
  #shopify-section-{{ section.id }} a.pagination__item:hover {
    border-color: var(--color-border, #c2c2c2);
  }
  #shopify-section-{{ section.id }} .pagination__item--current {
    border-color: var(--color-accent, #000);
    font-weight: bold;
  }
  @media screen and (max-width: 1000px) {
    #shopify-section-{{ section.id }} .collection__toolbar-bar {
      flex-direction: column;
      align-items: stretch;
    }
    #shopify-section-{{ section.id }} .collection__sort .select__select {
      min-width: 0;
      flex: 1;
    }
  }
</style>

{% schema %}
{
  "name": "t:sections.main_collection.name",
  "tag": "section",
  "class": "section-main-collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 16,
      "label": "t:sections.main_collection.settings.products_per_page.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "t:sections.main_collection.settings.columns_desktop.label"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "default": true,
      "label": "t:sections.main_collection.settings.enable_sorting.label"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "default": true,
      "label": "t:sections.main_collection.settings.enable_filtering.label"
    }
  ]
}
{% endschema %}
