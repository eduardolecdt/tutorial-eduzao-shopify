{%- comment -%}
  ============================================================
  MAIN SEARCH — página de resultados de busca
  ============================================================

  O QUE FAZ:
  Renderiza o formulário de busca e os resultados mistos da loja
  (produtos, artigos de blog e páginas) com paginação. Usa GET,
  funcionando sem JavaScript.

  ONDE É USADA:
  No template de busca (templates/search.json), como section
  principal da página /search.

  PRINCIPAIS PARTES:
  - search__form: form GET para routes.search_url com o input de
    busca (name="q") preenchido com search.terms.
  - Bloco de resultados exibido só quando search.performed:
    mostra estado vazio (no_results) ou a contagem de resultados.
  - {% paginate search.results by 20 %}: percorre os itens e, via
    case item.object_type, renderiza cada tipo — 'product' usa o
    snippet 'card-product'; 'article' e 'page' montam um link com
    título e trecho (excerpt/content). O else cobre outros tipos.
  - Snippet 'pagination' ao final da lista.

  OBSERVAÇÕES:
  - Não tem settings no schema — comportamento fixo.
  - Trechos de artigo/página usam strip_html + truncatewords: 25.
  - Estilos inline no <style>, escopados por
    #shopify-section-{{ section.id }}.
{%- endcomment -%}

<div class="search page-width" data-section-id="{{ section.id }}">
  <div class="search__header">
    <h1 class="search__title">{{ 'templates.search.title' | t }}</h1>

    <form action="{{ routes.search_url }}" method="get" role="search" class="search__form">
      <label class="visually-hidden" for="SearchInput-{{ section.id }}">
        {{ 'general.search.search' | t }}
      </label>
      <input
        type="search"
        name="q"
        id="SearchInput-{{ section.id }}"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'general.search.placeholder' | t }}"
        spellcheck="false"
        class="field__input search__input"
      >
      <button type="submit" class="button search__submit">
        {{ 'general.search.submit' | t }}
      </button>
    </form>
  </div>

  {%- if search.performed -%}
    {%- if search.results_count == 0 -%}
      <p class="search__empty">
        {{ 'templates.search.no_results' | t: terms: search.terms }}
      </p>
    {%- else -%}
      <p class="search__count">
        {%- if search.results_count == 1 -%}
          {{ 'templates.search.results_with_count' | t: count: search.results_count, terms: search.terms }}
        {%- else -%}
          {{ 'templates.search.results_with_count_plural' | t: count: search.results_count, terms: search.terms }}
        {%- endif -%}
      </p>

      {%- paginate search.results by 20 -%}
        <ul class="search__results product-grid" role="list">
          {%- for item in search.results -%}
            <li class="search__result">
              {%- case item.object_type -%}
                {%- when 'product' -%}
                  {% render 'card-product', card_product: item %}

                {%- when 'article' -%}
                  <a href="{{ item.url }}" class="search__result-link">
                    {%- if item.image -%}
                      <div class="search__result-media">
                        {{
                          item.image
                          | image_url: width: 720
                          | image_tag:
                            loading: 'lazy',
                            widths: '180, 360, 540, 720',
                            sizes: '(min-width: 1000px) 25vw, 50vw',
                            class: 'search__result-image',
                            alt: item.title | escape
                        }}
                      </div>
                    {%- endif -%}
                    <div class="search__result-info">
                      <h3 class="search__result-title">{{ item.title | escape }}</h3>
                      {%- if item.excerpt != blank -%}
                        <p class="search__result-excerpt">{{ item.excerpt | strip_html | truncatewords: 25 }}</p>
                      {%- endif -%}
                    </div>
                  </a>

                {%- when 'page' -%}
                  <a href="{{ item.url }}" class="search__result-link">
                    <div class="search__result-info">
                      <h3 class="search__result-title">{{ item.title | escape }}</h3>
                      {%- if item.content != blank -%}
                        <p class="search__result-excerpt">{{ item.content | strip_html | truncatewords: 25 }}</p>
                      {%- endif -%}
                    </div>
                  </a>

                {%- else -%}
                  <a href="{{ item.url }}" class="search__result-link">
                    <div class="search__result-info">
                      <h3 class="search__result-title">{{ item.title | escape }}</h3>
                    </div>
                  </a>
              {%- endcase -%}
            </li>
          {%- endfor -%}
        </ul>

        {% render 'pagination', paginate: paginate %}
      {%- endpaginate -%}
    {%- endif -%}
  {%- endif -%}
</div>

<style>
  #shopify-section-{{ section.id }} .search {
    margin-top: 24px;
    margin-bottom: var(--spacing-sections, 40px);
  }
  #shopify-section-{{ section.id }} .search__header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 32px;
  }
  #shopify-section-{{ section.id }} .search__title {
    font-size: var(--f6);
    margin: 0 0 16px;
  }
  #shopify-section-{{ section.id }} .search__form {
    display: flex;
    gap: 8px;
  }
  #shopify-section-{{ section.id }} .search__input {
    flex: 1;
  }
  #shopify-section-{{ section.id }} .search__count,
  #shopify-section-{{ section.id }} .search__empty {
    font-size: var(--f3);
    margin-bottom: 24px;
  }
  #shopify-section-{{ section.id }} .search__result-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  #shopify-section-{{ section.id }} .search__result-media {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--media-radius, 8px);
    background-color: var(--color-background-contrast, #f2f3f8);
  }
  #shopify-section-{{ section.id }} .search__result-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  #shopify-section-{{ section.id }} .search__result-info {
    padding: 12px 4px;
  }
  #shopify-section-{{ section.id }} .search__result-title {
    font-size: var(--f2);
    font-weight: normal;
    margin: 0 0 6px;
  }
  #shopify-section-{{ section.id }} .search__result-excerpt {
    font-size: var(--f1);
    opacity: 0.7;
    margin: 0;
  }
  #shopify-section-{{ section.id }} .pagination {
    margin-top: 40px;
  }
  #shopify-section-{{ section.id }} .pagination__list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 6px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  #shopify-section-{{ section.id }} .pagination__item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    min-height: 40px;
    padding: 0 8px;
    font-size: var(--f2);
    color: var(--color-text, #000);
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: var(--inputs-radius, 4px);
  }
  #shopify-section-{{ section.id }} a.pagination__item:hover {
    border-color: var(--color-border, #c2c2c2);
  }
  #shopify-section-{{ section.id }} .pagination__item--current {
    border-color: var(--color-accent, #000);
    font-weight: bold;
  }
  @media screen and (max-width: 1000px) {
    #shopify-section-{{ section.id }} .search__form {
      flex-direction: column;
    }
  }
</style>

{% schema %}
{
  "name": "t:sections.main_search.name",
  "tag": "section",
  "class": "section-main-search",
  "settings": []
}
{% endschema %}
