{%- comment -%}
  ============================================================
  PRODUCT SHOWCASE — vitrine de produtos com Add to Cart / Buy Now
  ============================================================

  O QUE FAZ:
  Grade de produtos, cada card com imagem, preço, título, descrição curta,
  tag e dois botões: "Add to Cart" (adiciona ao carrinho via AJAX/drawer)
  e "Buy Now" (leva à página do produto). No rodapé, botão opcional
  "See More Collections".

  ONDE É USADA:
  Home. Seção reutilizável — tem preset.

  ORIGEM DOS PRODUTOS (setting 'source'):
  - 'latest' (padrão): últimos produtos CRIADOS na loja, automático —
    usa collections.all.products ordenado por created_at (mais novos
    primeiro). Não precisa configurar coleção.
  - 'collection': produtos de uma coleção escolhida no editor.

  PRINCIPAIS PARTES:
  - product_source: resolvido no bloco {%- liquid -%} conforme 'source'
  - Para cada produto: {% form 'product' %} com data-type add-to-cart-form
    (interceptado por carrinho.js) para o Add to Cart
  - Placeholders quando não há produtos (loja nova / coleção vazia)
  - Settings: heading, source, collection, products_to_show,
    columns_desktop, show_description, show_view_all + view_all_label/link

  OBSERVAÇÕES ADICIONAIS:
  collections.all expõe até 50 produtos; o sort/reverse pega os mais
  recentes desse conjunto — suficiente para "novidades" na home.

  OBSERVAÇÕES:
  O Add to Cart usa a primeira variante disponível. Produtos com
  múltiplas variantes: o botão adiciona a variante padrão; para escolher
  opções o cliente abre a página do produto pelo título/imagem.
{%- endcomment -%}
{%- liquid
  assign limit = section.settings.products_to_show | plus: 0

  # Fonte dos produtos: 'latest' (últimos criados, automático) ou 'collection' (coleção escolhida)
  if section.settings.source == 'collection' and section.settings.collection != blank
    assign product_source = collections[section.settings.collection].products
    assign source_url = collections[section.settings.collection].url
  else
    # Últimos produtos criados: coleção 'all' ordenada por data de criação (mais novos primeiro)
    assign product_source = collections.all.products | sort: 'created_at' | reverse
    assign source_url = routes.all_products_collection_url
  endif
-%}
<div
  class="product-showcase page-width"
  data-section-id="{{ section.id }}"
  style="--grid-columns: {{ section.settings.columns_desktop }};"
>
  {%- if section.settings.heading != blank -%}
    <div class="product-showcase__header">
      <h2 class="product-showcase__heading">{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="product-showcase__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if product_source.size > 0 -%}
    <ul class="product-showcase__grid" role="list">
      {%- for product in product_source limit: limit -%}
        {%- assign variant = product.selected_or_first_available_variant -%}
        <li class="showcase-card">
          <a href="{{ product.url }}" class="showcase-card__media">
            {%- if product.featured_media -%}
              {{
                product.featured_media
                | image_url: width: 720
                | image_tag:
                  loading: 'lazy',
                  class: 'showcase-card__image',
                  widths: '240, 360, 540, 720',
                  sizes: '(min-width: 1000px) 33vw, 100vw',
                  alt: product.featured_media.alt | default: product.title | escape
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'showcase-card__image placeholder-svg' }}
            {%- endif -%}
          </a>

          <div class="showcase-card__info">
            <div class="showcase-card__toprow">
              {% render 'price', product: product, use_variant: true, show_compare: true, price_class: 'price--showcase' %}
              {%- if product.type != blank -%}
                <span class="showcase-card__tag">{{ product.type }}</span>
              {%- elsif product.tags.size > 0 -%}
                <span class="showcase-card__tag">{{ product.tags.first }}</span>
              {%- endif -%}
            </div>

            <a href="{{ product.url }}" class="showcase-card__title-link">
              <h3 class="showcase-card__title">{{ product.title | escape }}</h3>
            </a>

            {%- if section.settings.show_description and product.description != blank -%}
              <p class="showcase-card__desc">{{ product.description | strip_html | truncatewords: 18 }}</p>
            {%- endif -%}

            <div class="showcase-card__actions">
              {%- form 'product', product, data-type: 'add-to-cart-form', class: 'showcase-card__form' -%}
                <input type="hidden" name="id" value="{{ variant.id }}">
                <button
                  type="submit"
                  name="add"
                  class="button button--secondary showcase-card__add"
                  {% unless variant.available %}disabled{% endunless %}
                >
                  {%- if variant.available -%}
                    {{ 'products.product.add_to_cart' | t }}
                  {%- else -%}
                    {{ 'products.product.sold_out' | t }}
                  {%- endif -%}
                </button>
              {%- endform -%}
              <a href="{{ product.url }}" class="button showcase-card__buy">
                {{ 'products.product.buy_now' | t }}
              </a>
            </div>
          </div>
        </li>
      {%- endfor -%}
    </ul>
  {%- else -%}
    <ul class="product-showcase__grid" role="list">
      {%- for i in (1..limit) -%}
        <li class="showcase-card">
          <div class="showcase-card__media">{{ 'product-1' | placeholder_svg_tag: 'showcase-card__image placeholder-svg' }}</div>
          <div class="showcase-card__info">
            <div class="showcase-card__toprow"><span class="price price--showcase"><span class="price__regular">$0.00</span></span></div>
            <h3 class="showcase-card__title">{{ 'onboarding.product_title' | t }}</h3>
            <div class="showcase-card__actions">
              <span class="button button--secondary showcase-card__add">{{ 'products.product.add_to_cart' | t }}</span>
              <span class="button showcase-card__buy">Buy Now</span>
            </div>
          </div>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}

  {%- if section.settings.show_view_all -%}
    <div class="product-showcase__footer">
      <a
        href="{{ section.settings.view_all_link | default: source_url | default: '/collections/all' }}"
        class="button button--secondary product-showcase__view-all"
      >
        {{ section.settings.view_all_label | default: 'See More Collections' }}
      </a>
    </div>
  {%- endif -%}
</div>

<style>
  .product-showcase { padding-top: var(--spacing-sections); padding-bottom: var(--spacing-sections); }
  .product-showcase__header { text-align: center; margin-bottom: 36px; }
  .product-showcase__heading { font-size: var(--f7); }
  .product-showcase__subheading { font-size: var(--f2); opacity: 0.7; margin-top: 8px; max-width: 46ch; margin-inline: auto; }
  .product-showcase__grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-columns, 3), 1fr);
    gap: 28px;
    list-style: none; margin: 0; padding: 0;
  }
  .showcase-card { display: flex; flex-direction: column; }
  .showcase-card__media {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: var(--media-radius);
    background: var(--color-background-contrast);
  }
  .showcase-card__image { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .showcase-card:hover .showcase-card__image { transform: scale(1.04); }
  .showcase-card__info { padding: 14px 4px 0; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .showcase-card__toprow { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
  .price--showcase { font-size: var(--f5); font-weight: 600; }
  .showcase-card__tag {
    font-size: var(--f0);
    padding: 4px 10px;
    border: 1px solid var(--color-border);
    border-radius: 30px;
    white-space: nowrap;
    opacity: 0.85;
  }
  .showcase-card__title-link { text-decoration: none; color: inherit; }
  .showcase-card__title { font-size: var(--f3); font-weight: 500; }
  .showcase-card__desc { font-size: var(--f1); opacity: 0.65; line-height: 1.5; }
  .showcase-card__actions { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: auto; padding-top: 8px; }
  .showcase-card__form { margin: 0; }
  .showcase-card__add { width: 100%; }
  .showcase-card__buy { width: 100%; }
  .product-showcase__footer { display: flex; justify-content: center; margin-top: 40px; }
  .product-showcase__view-all { padding: 14px 34px; }

  @media screen and (max-width: 1000px) {
    .product-showcase__grid { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "Product showcase",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título" },
    { "type": "text", "id": "subheading", "label": "Subtítulo" },
    {
      "type": "radio",
      "id": "source",
      "options": [
        { "value": "latest", "label": "Últimos produtos criados (automático)" },
        { "value": "collection", "label": "Coleção específica" }
      ],
      "default": "latest",
      "label": "Origem dos produtos"
    },
    { "type": "collection", "id": "collection", "label": "Coleção", "info": "Usada apenas quando a origem é \"Coleção específica\"." },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "default": 3, "label": "Produtos exibidos" },
    { "type": "range", "id": "columns_desktop", "min": 2, "max": 4, "step": 1, "default": 3, "label": "Colunas (desktop)" },
    { "type": "checkbox", "id": "show_description", "default": true, "label": "Mostrar descrição curta" },
    { "type": "checkbox", "id": "show_view_all", "default": true, "label": "Mostrar botão inferior" },
    { "type": "text", "id": "view_all_label", "default": "See More Collections", "label": "Texto do botão inferior" },
    { "type": "url", "id": "view_all_link", "label": "Link do botão inferior" }
  ],
  "presets": [{ "name": "Product showcase" }]
}
{% endschema %}
