{%- comment -%}
  ============================================================
  HERO SNEAKERS — banner hero editorial (estilo campanha)
  ============================================================

  O QUE FAZ:
  Banner de destaque no estilo campanha de sneakers: imagem grande à
  direita, título serifado gigante à esquerda com botão "pill" e, no
  canto inferior direito, um par de setas decorativas (slider fake).
  Fundo em tom terroso quando não há imagem.

  ONDE É USADA:
  Topo da home (index.json). Seção reutilizável — tem preset.

  PRINCIPAIS PARTES:
  - Imagem eager + fetchpriority high (é o hero, carrega primeiro)
  - Placeholder com gradiente terroso quando sem imagem
  - Blocks: heading, text, button (cada um limit 1)
  - Settings: image, overlay_opacity, content_position (left/right)
  - As setas são decorativas (aria-hidden), só marcam o visual do print

  OBSERVAÇÕES:
  Título usa a fonte de heading do tema (serifada de display).
  No mobile o conteúdo vira coluna única centralizada sobre a imagem.
{%- endcomment -%}
<div
  class="hero-sneakers hero-sneakers--{{ section.settings.content_position }}"
  data-section-id="{{ section.id }}"
  style="--overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
>
  <div class="hero-sneakers__media">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 3000
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          class: 'hero-sneakers__image',
          widths: '800, 1200, 1600, 2000, 3000',
          sizes: '100vw',
          alt: section.settings.image.alt | default: section.settings.heading | escape
      }}
    {%- elsif section.settings.image_asset != blank -%}
      <img
        src="{{ section.settings.image_asset | asset_url }}"
        class="hero-sneakers__image"
        loading="eager"
        fetchpriority="high"
        alt="{{ section.settings.heading | escape }}"
      >
    {%- else -%}
      <div class="hero-sneakers__image hero-sneakers__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {%- endif -%}
  </div>

  <div class="hero-sneakers__inner page-width">
    <div class="hero-sneakers__content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h1 class="hero-sneakers__heading" {{ block.shopify_attributes }}>{{ block.settings.heading | escape }}</h1>
          {%- when 'text' -%}
            <div class="hero-sneakers__text rte" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
          {%- when 'button' -%}
            {%- if block.settings.button_label != blank -%}
              <a
                href="{{ block.settings.button_link | default: '#' }}"
                class="button hero-sneakers__button"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.button_label | escape }}
              </a>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>

  {%- if section.settings.show_arrows -%}
    <div class="hero-sneakers__arrows" aria-hidden="true">
      <span class="hero-sneakers__arrow">{% render 'icon', name: 'chevron-left' %}</span>
      <span class="hero-sneakers__arrow hero-sneakers__arrow--active">{% render 'icon', name: 'chevron-right' %}</span>
    </div>
  {%- endif -%}
</div>

<style>
  .hero-sneakers {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 78vh;
    overflow: hidden;
    border-radius: var(--media-radius);
    margin: 12px auto 0;
    max-width: calc(var(--page-width) + 40px);
  }
  .hero-sneakers__media { position: absolute; inset: 0; z-index: 0; }
  .hero-sneakers__image { width: 100%; height: 100%; object-fit: cover; }
  .hero-sneakers__placeholder {
    display: grid;
    place-items: center;
    background: linear-gradient(120deg, #6b5238 0%, #8a6c48 45%, #cdbfa6 100%);
  }
  .hero-sneakers::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(90deg, rgba(35,26,20,calc(0.55 * var(--overlay, 0.35))) 0%, rgba(35,26,20,calc(0.15 * var(--overlay, 0.35))) 55%, rgba(35,26,20,0) 100%);
  }
  .hero-sneakers--right::after {
    background: linear-gradient(270deg, rgba(35,26,20,calc(0.55 * var(--overlay, 0.35))) 0%, rgba(35,26,20,calc(0.15 * var(--overlay, 0.35))) 55%, rgba(35,26,20,0) 100%);
  }
  .hero-sneakers__inner { position: relative; z-index: 2; width: 100%; }
  .hero-sneakers--right .hero-sneakers__content { margin-left: auto; text-align: right; }
  .hero-sneakers__content { max-width: 560px; padding: 40px 0; }
  .hero-sneakers__heading {
    font-size: clamp(2.6rem, 6vw, 5.4rem);
    line-height: 1.02;
    color: var(--color-accent-text);
    margin-bottom: 28px;
    text-shadow: 0 2px 24px rgba(0,0,0,0.28);
  }
  .hero-sneakers__text { font-size: var(--f3); color: var(--color-accent-text); margin-bottom: 28px; max-width: 42ch; text-shadow: 0 1px 12px rgba(0,0,0,0.3); }
  .hero-sneakers--right .hero-sneakers__text { margin-left: auto; }
  .hero-sneakers__button {
    background: var(--color-background);
    color: var(--color-text);
    border-color: var(--color-background);
    padding: 16px 40px;
    font-size: var(--f3);
    box-shadow: 0 8px 30px rgba(0,0,0,0.15);
  }
  .hero-sneakers__button:hover { opacity: 1; transform: translateY(-2px); }
  .hero-sneakers__arrows {
    position: absolute;
    right: 24px;
    bottom: 24px;
    z-index: 2;
    display: flex;
    gap: 10px;
  }
  .hero-sneakers__arrow {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: rgba(35,26,20,0.55);
    color: #fff;
    backdrop-filter: blur(4px);
  }
  .hero-sneakers__arrow--active { background: var(--color-accent); }
  .hero-sneakers__arrow svg { width: 18px; height: 18px; }

  @media screen and (max-width: 1000px) {
    .hero-sneakers { min-height: 70vh; }
    .hero-sneakers__content,
    .hero-sneakers--right .hero-sneakers__content { max-width: 100%; text-align: center; margin: 0 auto; }
    .hero-sneakers__text { margin-left: auto; margin-right: auto; }
    .hero-sneakers::after { background: linear-gradient(0deg, rgba(35,26,20,0.7) 0%, rgba(35,26,20,0.2) 60%, rgba(35,26,20,0.2) 100%); }
    .hero-sneakers__arrows { display: none; }
  }
</style>

{% schema %}
{
  "name": "Hero sneakers",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Imagem de fundo" },
    { "type": "text", "id": "image_asset", "label": "Imagem via asset (fallback)", "info": "Nome do arquivo em assets/ usado quando nenhuma imagem é selecionada acima. Ex.: home-hero.webp" },
    {
      "type": "select",
      "id": "content_position",
      "options": [
        { "value": "left", "label": "Esquerda" },
        { "value": "right", "label": "Direita" }
      ],
      "default": "left",
      "label": "Posição do conteúdo"
    },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 100, "step": 5, "default": 40, "unit": "%", "label": "Escurecer imagem" },
    { "type": "checkbox", "id": "show_arrows", "default": true, "label": "Mostrar setas decorativas" }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Título",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "default": "Sneakers That Fit Your Everyday Look", "label": "Título" }
      ]
    },
    {
      "type": "text",
      "name": "Texto",
      "limit": 1,
      "settings": [
        { "type": "richtext", "id": "text", "default": "<p>Estilo, conforto e as silhuetas mais desejadas do momento.</p>", "label": "Texto" }
      ]
    },
    {
      "type": "button",
      "name": "Botão",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "button_label", "default": "Shop Now", "label": "Texto do botão" },
        { "type": "url", "id": "button_link", "label": "Link do botão" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero sneakers",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
