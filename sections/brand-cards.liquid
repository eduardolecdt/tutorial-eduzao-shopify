{%- comment -%}
  ============================================================
  BRAND CARDS — cartões de destaque com imagem + CTA sobreposto
  ============================================================

  O QUE FAZ:
  Fileira de cartões grandes (padrão 3) com imagem de fundo, um texto
  de chamada no rodapé e um botão. Serve para destacar marcas,
  coleções ou campanhas na home, no estilo editorial do print.

  ONDE É USADA:
  Home, logo abaixo do hero. Seção reutilizável — tem preset com 3 blocos.

  PRINCIPAIS PARTES:
  - section.blocks do tipo 'card' (image, heading, text, button_label, link)
  - Cada card é um link inteiro clicável (a.brand-card)
  - Layout via --grid-columns inline no wrapper
  - Alinhamento do conteúdo (topo/centro/base) por card

  OBSERVAÇÕES:
  Botão e título ficam sobre a imagem com overlay em degradê para
  legibilidade. No mobile vira 1 coluna.
{%- endcomment -%}
<div
  class="brand-cards page-width"
  data-section-id="{{ section.id }}"
  style="--grid-columns: {{ section.blocks.size }};"
>
  {%- if section.settings.heading != blank -%}
    <h2 class="brand-cards__heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <div class="brand-cards__grid">
    {%- for block in section.blocks -%}
      <a
        href="{{ block.settings.link | default: '#' }}"
        class="brand-card brand-card--{{ block.settings.content_align }}"
        {{ block.shopify_attributes }}
      >
        <div class="brand-card__media">
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                class: 'brand-card__image',
                widths: '400, 600, 900, 1200',
                sizes: '(min-width: 1000px) 33vw, 100vw',
                alt: block.settings.image.alt | default: block.settings.heading | escape
            }}
          {%- elsif block.settings.image_asset != blank -%}
            <img
              src="{{ block.settings.image_asset | asset_url }}"
              class="brand-card__image"
              loading="lazy"
              alt="{{ block.settings.heading | escape }}"
            >
          {%- else -%}
            <div class="brand-card__image brand-card__placeholder">
              {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>

        <div class="brand-card__content">
          {%- if block.settings.heading != blank -%}
            <h3 class="brand-card__title">{{ block.settings.heading | escape }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="brand-card__text">{{ block.settings.text | escape }}</p>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <span class="button brand-card__button">{{ block.settings.button_label | escape }}</span>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

<style>
  .brand-cards { padding-top: var(--spacing-sections); padding-bottom: var(--spacing-sections); }
  .brand-cards__heading { font-size: var(--f7); text-align: center; margin-bottom: 32px; }
  .brand-cards__grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-columns, 3), 1fr);
    gap: 20px;
  }
  .brand-card {
    position: relative;
    display: block;
    min-height: 440px;
    border-radius: var(--media-radius);
    overflow: hidden;
    text-decoration: none;
    color: #fff;
    isolation: isolate;
  }
  .brand-card__media { position: absolute; inset: 0; z-index: 0; }
  .brand-card__image { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
  .brand-card__placeholder { display: grid; place-items: center; background: linear-gradient(140deg, #7a5c3d, #cdbfa6); }
  .brand-card:hover .brand-card__image { transform: scale(1.05); }
  .brand-card::after {
    content: '';
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(180deg, rgba(35,26,20,0) 30%, rgba(35,26,20,0.75) 100%);
  }
  .brand-card__content {
    position: relative; z-index: 2;
    display: flex; flex-direction: column; align-items: flex-start; gap: 14px;
    height: 100%;
    padding: 28px;
  }
  .brand-card--top .brand-card__content { justify-content: flex-start; text-align: left; }
  .brand-card--center .brand-card__content { justify-content: center; align-items: center; text-align: center; }
  .brand-card--bottom .brand-card__content { justify-content: flex-end; text-align: left; }
  .brand-card__title { font-size: var(--f7); color: #fff; text-shadow: 0 2px 16px rgba(0,0,0,0.4); }
  .brand-card__text { font-size: var(--f3); max-width: 26ch; text-shadow: 0 1px 10px rgba(0,0,0,0.5); }
  .brand-card__button {
    background: var(--color-background);
    color: var(--color-text);
    border-color: var(--color-background);
    pointer-events: none;
  }
  .brand-card:hover .brand-card__button { opacity: 0.9; }

  @media screen and (max-width: 1000px) {
    .brand-cards__grid { grid-template-columns: 1fr; }
    .brand-card { min-height: 360px; }
  }
</style>

{% schema %}
{
  "name": "Brand cards",
  "tag": "section",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "heading", "label": "Título da seção (opcional)" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Cartão",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagem" },
        { "type": "text", "id": "image_asset", "label": "Imagem via asset (fallback)", "info": "Ex.: home-brand-1.webp" },
        { "type": "text", "id": "heading", "label": "Título" },
        { "type": "text", "id": "text", "label": "Texto" },
        { "type": "text", "id": "button_label", "default": "Shop Now", "label": "Texto do botão" },
        { "type": "url", "id": "link", "label": "Link do cartão" },
        {
          "type": "select",
          "id": "content_align",
          "options": [
            { "value": "top", "label": "Topo" },
            { "value": "center", "label": "Centro" },
            { "value": "bottom", "label": "Base" }
          ],
          "default": "bottom",
          "label": "Posição do conteúdo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand cards",
      "blocks": [
        { "type": "card", "settings": { "image_asset": "home-brand-1.webp", "heading": "", "text": "Sneakers que acompanham você. Confortáveis, duráveis e sempre no estilo.", "button_label": "Find Your Fit", "content_align": "bottom" } },
        { "type": "card", "settings": { "image_asset": "home-brand-2.webp", "heading": "", "text": "Fresh Drops. Silhuetas icônicas que falam antes de você.", "button_label": "Get Your Pair", "content_align": "bottom" } },
        { "type": "card", "settings": { "image_asset": "home-brand-3.webp", "heading": "STYLE-STACK", "text": "", "button_label": "Shop Sneakers", "content_align": "center" } }
      ]
    }
  ]
}
{% endschema %}
