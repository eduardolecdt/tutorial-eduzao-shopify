{%- comment -%}
  ============================================================
  COLLECTIONS MOSAIC — mosaico de coleções recomendadas
  ============================================================

  O QUE FAZ:
  Bloco editorial com um título/subtítulo centralizado e um mosaico:
  um cartão grande à esquerda + cartões menores à direita, cada um com
  imagem, rótulo e botão "View all". Estilo do print "Most Recommend
  Collections For You".

  ONDE É USADA:
  Home. Seção reutilizável — tem preset com 3 blocos.

  PRINCIPAIS PARTES:
  - section.blocks do tipo 'tile' (image, label, button_label, link)
  - O 1º bloco vira o cartão grande (ocupa 2 linhas na coluna esquerda)
  - Demais blocos empilham na coluna direita
  - Settings: heading, subheading

  OBSERVAÇÕES:
  Ideal com 3 blocos (1 grande + 2 pequenos). Com mais blocos, eles
  seguem preenchendo a grade. No mobile tudo vira 1 coluna.
{%- endcomment -%}
<div class="collections-mosaic page-width" data-section-id="{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <div class="collections-mosaic__header">
      <h2 class="collections-mosaic__heading">{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="collections-mosaic__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="collections-mosaic__grid">
    {%- for block in section.blocks -%}
      <a
        href="{{ block.settings.link | default: '#' }}"
        class="mosaic-tile {% if forloop.first %}mosaic-tile--large{% endif %}"
        {{ block.shopify_attributes }}
      >
        <div class="mosaic-tile__media">
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 1400
              | image_tag:
                loading: 'lazy',
                class: 'mosaic-tile__image',
                widths: '400, 700, 1000, 1400',
                sizes: '(min-width: 1000px) 50vw, 100vw',
                alt: block.settings.label | escape
            }}
          {%- elsif block.settings.image_asset != blank -%}
            <img
              src="{{ block.settings.image_asset | asset_url }}"
              class="mosaic-tile__image"
              loading="lazy"
              alt="{{ block.settings.label | escape }}"
            >
          {%- else -%}
            <div class="mosaic-tile__image mosaic-tile__placeholder">
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>
        <div class="mosaic-tile__content">
          {%- if block.settings.label != blank -%}
            <span class="mosaic-tile__label">{{ block.settings.label | escape }}</span>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <span class="button mosaic-tile__button">{{ block.settings.button_label | escape }}</span>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

<style>
  .collections-mosaic { padding-top: var(--spacing-sections); padding-bottom: var(--spacing-sections); }
  .collections-mosaic__header { text-align: center; margin-bottom: 40px; }
  .collections-mosaic__heading { font-size: clamp(2rem, 4vw, 3.4rem); }
  .collections-mosaic__subheading { font-size: var(--f2); opacity: 0.7; margin-top: 10px; max-width: 46ch; margin-inline: auto; }
  .collections-mosaic__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-auto-rows: 240px;
    gap: 20px;
  }
  .mosaic-tile {
    position: relative;
    display: block;
    border-radius: var(--media-radius);
    overflow: hidden;
    text-decoration: none;
    isolation: isolate;
  }
  .mosaic-tile--large { grid-row: span 2; }
  .mosaic-tile__media { position: absolute; inset: 0; z-index: 0; }
  .mosaic-tile__image { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
  .mosaic-tile__placeholder { display: grid; place-items: center; background: linear-gradient(140deg, #7a5c3d, #cdbfa6); height: 100%; }
  .mosaic-tile:hover .mosaic-tile__image { transform: scale(1.05); }
  .mosaic-tile::after {
    content: '';
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(180deg, rgba(35,26,20,0.15) 0%, rgba(35,26,20,0.05) 40%, rgba(35,26,20,0.55) 100%);
  }
  .mosaic-tile__content {
    position: relative; z-index: 2;
    height: 100%;
    padding: 24px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    gap: 14px;
    color: #fff;
  }
  .mosaic-tile__label { font-family: var(--font-heading-family); font-size: var(--f6); text-shadow: 0 2px 14px rgba(0,0,0,0.45); }
  .mosaic-tile__button {
    background: var(--color-background);
    color: var(--color-text);
    border-color: var(--color-background);
    pointer-events: none;
    min-height: 40px;
    padding: 8px 22px;
    font-size: var(--f1);
  }
  .mosaic-tile:hover .mosaic-tile__button { opacity: 0.9; }

  @media screen and (max-width: 1000px) {
    .collections-mosaic__grid { grid-template-columns: 1fr; grid-auto-rows: 220px; }
    .mosaic-tile--large { grid-row: span 1; min-height: 300px; }
  }
</style>

{% schema %}
{
  "name": "Collections mosaic",
  "tag": "section",
  "max_blocks": 5,
  "settings": [
    { "type": "text", "id": "heading", "default": "Most Recommend Collections For You", "label": "Título" },
    { "type": "text", "id": "subheading", "default": "Dos clássicos atemporais aos lançamentos, tênis autênticos feitos para estilo e conforto.", "label": "Subtítulo" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Bloco",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagem" },
        { "type": "text", "id": "image_asset", "label": "Imagem via asset (fallback)", "info": "Ex.: home-mosaic-1.webp" },
        { "type": "text", "id": "label", "default": "Sneakers", "label": "Rótulo" },
        { "type": "text", "id": "button_label", "default": "View all sneakers", "label": "Texto do botão" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collections mosaic",
      "blocks": [
        { "type": "tile", "settings": { "image_asset": "home-mosaic-1.webp", "label": "Sneakers", "button_label": "View all sneakers" } },
        { "type": "tile", "settings": { "image_asset": "home-mosaic-2.webp", "label": "Sneakers", "button_label": "View all sneakers" } },
        { "type": "tile", "settings": { "image_asset": "home-mosaic-3.webp", "label": "Sneakers", "button_label": "View all sneakers" } }
      ]
    }
  ]
}
{% endschema %}
