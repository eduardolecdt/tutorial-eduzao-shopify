{%- comment -%}
  ============================================================
  MAIN PASSWORD — página de senha da loja (loja fechada)
  ============================================================

  O QUE FAZ:
  Tela exibida quando a loja está protegida por senha (ainda não
  aberta ao público). Mostra logo/nome da loja, mensagem do lojista
  e o formulário nativo de senha para entrar na vitrine.

  ONDE É USADA:
  Template password (a "porta de entrada" enquanto a loja está fechada).

  PRINCIPAIS PARTES:
  - settings.logo: logo da loja; se não houver, mostra shop.name
  - shop.password_message: mensagem configurada no admin
  - form 'storefront_password': valida a senha da vitrine
  - Bloco de erro reaproveita as classes .contact__notice

  OBSERVAÇÕES:
  Não confundir com login de cliente — aqui é a senha global da loja.
{%- endcomment -%}

{%- assign form_id = 'PasswordLoginForm-' | append: section.id -%}

<section class="password page-width" data-section-id="{{ section.id }}">
  <div class="password__inner">
    <div class="password__logo">
      {%- if settings.logo != blank -%}
        {{
          settings.logo
          | image_url: width: 600
          | image_tag:
            widths: '150, 300, 450, 600',
            sizes: '(min-width: 1000px) 300px, 60vw',
            class: 'password__logo-image',
            alt: shop.name | escape
        }}
      {%- else -%}
        <h1 class="password__shop-name">{{ shop.name }}</h1>
      {%- endif -%}
    </div>

    {%- if shop.password_message != blank -%}
      <div class="password__message rte">
        {{ shop.password_message }}
      </div>
    {%- endif -%}

    {%- form 'storefront_password', id: form_id, class: 'password__form' -%}
      {%- if form.errors -%}
        <div class="contact__notice contact__notice--error" role="alert" tabindex="-1">
          {{ form.errors.translated_fields['password'] | capitalize }}
          {{ form.errors.messages['password'] }}
        </div>
      {%- endif -%}

      <div class="password__field">
        <label class="field__label" for="Password-{{ section.id }}">
          {{ 'general.password_page.password_label' | t }}
        </label>
        <input
          type="password"
          class="field__input"
          id="Password-{{ section.id }}"
          name="password"
          autocomplete="current-password"
          autocapitalize="off"
          spellcheck="false"
          placeholder="{{ 'general.password_page.password_placeholder' | t }}"
        >
      </div>

      <button type="submit" class="button password__submit">
        {{ 'general.password_page.submit' | t }}
      </button>
    {%- endform -%}
  </div>
</section>

<style>
  .password {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: var(--spacing-sections, 40px);
    padding-bottom: var(--spacing-sections, 40px);
  }

  .password__inner {
    width: 100%;
    max-width: 420px;
    text-align: center;
  }

  .password__logo {
    margin-bottom: 24px;
  }

  .password__logo-image {
    max-width: 300px;
    height: auto;
    margin: 0 auto;
    display: block;
  }

  .password__shop-name {
    font-size: var(--f7);
  }

  .password__message {
    margin-bottom: 28px;
    font-size: var(--f2);
    line-height: 1.7;
  }

  .password__field {
    margin-bottom: 16px;
    text-align: left;
  }

  .password__submit {
    width: 100%;
  }

  @media screen and (max-width: 1000px) {
    .password__shop-name {
      font-size: var(--f6);
    }
  }
</style>

{% schema %}
{
  "name": "t:sections.main_password.name",
  "tag": "section",
  "class": "section-main-password",
  "settings": []
}
{% endschema %}
