{%- comment -%}
  ============================================================
  product-variant-selection — seleção de variante (client-side)
  ============================================================

  O QUE FAZ:
  Script que controla a seleção de variante na página de produto, sem
  depender de app: atualiza o id da variante (input hidden), o preço
  (HTML pré-renderizado por variante), o estado do botão "adicionar ao
  carrinho", troca a mídia em destaque e mantém ?variant na URL.
  Também controla os botões +/- do seletor de quantidade.

  COMO USAR:
  {% render 'product-variant-selection', section_id: section.id, product_form_id: product_form_id %}

  PARÂMETROS:
  - section_id: id da section (para achar [data-section-id] e a galeria).
  - product_form_id: id do <form> de compra do produto.

  OBSERVAÇÕES:
  Depende de marcações no HTML da section: [data-variant-json] com o JSON
  das variantes, .product__option com radios, .product-variant-id,
  .product__add-to-cart, .product__price e a galeria #ProductMedia-{section_id}.
{%- endcomment -%}
<script>
  (function () {
    var section = document.querySelector('[data-section-id="{{ section_id }}"]');
    if (!section) return;
    var form = document.getElementById('{{ product_form_id }}');
    var jsonEl = section.querySelector('[data-variant-json]');
    if (!form || !jsonEl) return;

    var variants;
    try { variants = JSON.parse(jsonEl.textContent); } catch (e) { return; }

    var idInput = form.querySelector('.product-variant-id');
    var addButton = form.querySelector('.product__add-to-cart');
    var addButtonText = addButton ? addButton.querySelector('span') : null;
    var priceContainer = section.querySelector('.product__price');
    var gallery = document.getElementById('ProductMedia-{{ section_id }}');

    var ADD = '{{ 'products.product.add_to_cart' | t }}';
    var SOLD_OUT = '{{ 'products.product.sold_out' | t }}';
    var UNAVAILABLE = '{{ 'products.product.unavailable' | t }}';

    function selectedOptions() {
      var opts = [];
      section.querySelectorAll('.product__option').forEach(function (fieldset) {
        var checked = fieldset.querySelector('input[type="radio"]:checked');
        if (checked) opts.push(checked.value);
      });
      return opts;
    }

    function findVariant(opts) {
      return variants.find(function (v) {
        return v.options.length === opts.length && v.options.every(function (o, i) { return o === opts[i]; });
      });
    }

    function setButton(disabled, text) {
      if (!addButton) return;
      if (disabled) { addButton.setAttribute('disabled', 'disabled'); }
      else { addButton.removeAttribute('disabled'); }
      if (addButtonText && text) { addButtonText.textContent = text; }
    }

    function updateUI() {
      var variant = findVariant(selectedOptions());

      if (!variant) {
        setButton(true, UNAVAILABLE);
        if (idInput) { idInput.setAttribute('disabled', 'disabled'); }
        return;
      }

      if (idInput) { idInput.value = variant.id; idInput.removeAttribute('disabled'); }
      setButton(!variant.available, variant.available ? ADD : SOLD_OUT);

      // Replace the whole price block with the store-formatted HTML for this variant.
      if (priceContainer && variant.price_html) {
        var existing = priceContainer.querySelector('.price');
        if (existing) {
          var tmp = document.createElement('div');
          tmp.innerHTML = variant.price_html;
          var fresh = tmp.querySelector('.price');
          if (fresh) { existing.replaceWith(fresh); }
        }
      }

      // Swap the featured media to the one tied to this variant.
      if (gallery && variant.featured_media_id) {
        var target = gallery.querySelector('[data-media-id="' + variant.featured_media_id + '"]');
        if (target) { target.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }
      }

      // Keep the URL shareable.
      if (window.history && history.replaceState) {
        var url = new URL(window.location.href);
        url.searchParams.set('variant', variant.id);
        history.replaceState({}, '', url.toString());
      }
    }

    section.querySelectorAll('.product__option input[type="radio"]').forEach(function (input) {
      input.addEventListener('change', function () {
        var option = input.closest('.product__option');
        option.querySelectorAll('.product__swatch').forEach(function (l) { l.classList.remove('is-selected'); });
        var label = input.closest('.product__swatch');
        if (label) label.classList.add('is-selected');
        updateUI();
      });
    });

    section.querySelectorAll('.quantity-selector').forEach(function (sel) {
      var input = sel.querySelector('.quantity__input');
      var plus = sel.querySelector('[name="plus"]');
      var minus = sel.querySelector('[name="minus"]');
      if (plus) plus.addEventListener('click', function () { input.value = parseInt(input.value || '1', 10) + 1; });
      if (minus) minus.addEventListener('click', function () { input.value = Math.max(1, parseInt(input.value || '1', 10) - 1); });
    });
  })();
</script>
